# ── Supabase (Required) ──
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ── Supabase Edge Function Secrets (set via CLI or dashboard) ──
# These are NOT Vite env vars — they are injected into edge functions at runtime.
# Set them with: npx supabase secrets set APOLLO_API_KEY=xxx

# Apollo.io — B2B contact enrichment (Required for lead enrichment)
APOLLO_API_KEY="your-apollo-api-key"

# Perplexity — AI web research with evidence-backed signals (Required for lead research)
PERPLEXITY_API_KEY="your-perplexity-api-key"

# OpenRouter — AI gateway for email drafts & content generation (Required for email campaigns)
OPENROUTER_API_KEY="your-openrouter-api-key"

# ScrapingBee — Website scraper (Required for company website intelligence)
SCRAPINGBEE_API_KEY="your-scrapingbee-api-key"

# Resend — Email sending (Required for campaigns & payslips)
RESEND_API_KEY="your-resend-api-key"
RESEND_WEBHOOK_SECRET="your-webhook-secret"

# Google Service Account — Drive integration (Required for payslip processing)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# ── Deprecated / Removed ──
# LOVABLE_API_KEY was previously used for email drafts.
# Replaced by OPENROUTER_API_KEY in generate-email-draft.
